# agent-dimension — cp .env.example .env (gitignored). Details: README.md
#
# Model spec: provider:model-id  (aliases: gemini, grok, mistral)
# Order: {ROLE}_LLM_MODEL → SUBAGENT_LLM_MODEL → LLM_MODEL → CLAUDE_MODEL → default
# Providers: openai, anthropic, google_genai, ollama, deepseek, xai, groq, mistralai

LLM_MODEL=anthropic:claude-opus-4-8
# CLAUDE_MODEL=claude-opus-4-8
# SUBAGENT_LLM_MODEL=google_genai:gemini-2.0-flash
# WORKER_LLM_MODEL=groq:llama-3.3-70b-versatile
# SKEPTIC_LLM_MODEL=xai:grok-3

# Keys — set one per provider you use (ollama needs none)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=sk-...
# XAI_API_KEY=xai-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...