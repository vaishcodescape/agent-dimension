# =============================================================================
# agent-dimension — environment configuration
# =============================================================================
#
# Setup:
#   cp .env.example .env
#   # Edit .env with your API keys and preferences.
#
# .env is gitignored — never commit secrets.
#
# Resolution order (models):
#   1. Per-role override   e.g. WORKER_LLM_MODEL
#   2. SUBAGENT_LLM_MODEL  (all subagents / discussants)
#   3. LLM_MODEL           (orchestrator default)
#   4. CLAUDE_MODEL        (legacy; bare id → anthropic:...)
#   5. Built-in default    anthropic:claude-opus-4-8
#
# Model spec format: provider:model-id
#   Supported providers: openai, anthropic, google_genai, ollama, deepseek,
#   xai, groq, mistralai
#   Aliases in specs: gemini → google_genai, grok → xai, mistral → mistralai
#
# Boolean env vars accept: 1, true, yes, on  (or 0, false, no, off)
# =============================================================================


# -----------------------------------------------------------------------------
# Default model (orchestrator)
# -----------------------------------------------------------------------------

# Primary model for the orchestrator agent.
# Required: API key for the chosen provider (see below).
#
# Examples:
#   LLM_MODEL=anthropic:claude-opus-4-8
#   LLM_MODEL=openai:gpt-4.1
#   LLM_MODEL=gemini:gemini-2.5-pro
#   LLM_MODEL=ollama:llama3.2
#   LLM_MODEL=deepseek:deepseek-chat
#   LLM_MODEL=grok:grok-3
#   LLM_MODEL=groq:llama-3.3-70b-versatile
#   LLM_MODEL=mistral:mistral-large-latest
#
# Default: anthropic:claude-opus-4-8
LLM_MODEL=anthropic:claude-opus-4-8

# Legacy fallback if LLM_MODEL is unset. A bare model id (no colon) is treated
# as Anthropic, e.g. CLAUDE_MODEL=claude-opus-4-8 → anthropic:claude-opus-4-8
# CLAUDE_MODEL=claude-opus-4-8


# -----------------------------------------------------------------------------
# Per-agent model overrides (optional)
# -----------------------------------------------------------------------------

# Fallback for every subagent and discussant when no role-specific override is set.
# SUBAGENT_LLM_MODEL=google_genai:gemini-2.0-flash

# Role-specific overrides. Pattern: {ROLE}_LLM_MODEL (uppercase role name).
# Applies to task team and discussion panel members.
#
# Task team:
#   PLANNER_LLM_MODEL=anthropic:claude-sonnet-4-6
#   WORKER_LLM_MODEL=groq:llama-3.3-70b-versatile
#   CRITIC_LLM_MODEL=openai:gpt-4.1-mini
#
# Discussion panel:
#   OPTIMIST_LLM_MODEL=anthropic:claude-opus-4-8
#   SKEPTIC_LLM_MODEL=xai:grok-3
#   PRAGMATIST_LLM_MODEL=deepseek:deepseek-chat


# -----------------------------------------------------------------------------
# Provider API keys
# -----------------------------------------------------------------------------
# Set the key(s) for every provider you use. Startup checks fail fast with a
# clear message if a required key is missing.
#
# Provider          | Env var(s)              | Get a key
# ------------------|-------------------------|----------------------------------
# Anthropic         | ANTHROPIC_API_KEY       | https://console.anthropic.com/
# OpenAI            | OPENAI_API_KEY          | https://platform.openai.com/
# Gemini            | GOOGLE_API_KEY or       | https://aistudio.google.com/apikey
#                   | GEMINI_API_KEY          |
# DeepSeek          | DEEPSEEK_API_KEY        | https://platform.deepseek.com/
# xAI (Grok)        | XAI_API_KEY             | https://console.x.ai/
# Groq              | GROQ_API_KEY            | https://console.groq.com/
# Mistral           | MISTRAL_API_KEY         | https://console.mistral.ai/
# Ollama            | (none — local server)   | https://ollama.com/
#
# Install the matching langchain-* package (see requirements.txt) for each
# provider you enable.

ANTHROPIC_API_KEY=sk-ant-...

# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=sk-...
# XAI_API_KEY=xai-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...


# -----------------------------------------------------------------------------
# Output limits (all providers)
# -----------------------------------------------------------------------------

# Max output tokens per model turn.
# Checked as LLM_MAX_TOKENS first, then CLAUDE_MAX_TOKENS, then default 64000.
# LLM_MAX_TOKENS=64000

# Sampling temperature for non-Anthropic providers (float, e.g. 0.7).
# Anthropic models ignore this unless you pass temperature in code.
# LLM_TEMPERATURE=0.7


# -----------------------------------------------------------------------------
# Anthropic-only: adaptive thinking
# -----------------------------------------------------------------------------
# These apply only when the resolved provider is anthropic.

# Enable adaptive extended thinking. Default: true
# Accepted: 1/0, true/false, yes/no, on/off
# CLAUDE_THINKING=true
# LLM_THINKING=true

# Reasoning effort for adaptive thinking.
# Values: max | xhigh | high | medium | low
# Checked: CLAUDE_EFFORT, then LLM_EFFORT, then default max
# CLAUDE_EFFORT=max

# Advisory token budget for multi-step agentic loops (not a hard cap).
# Checked: CLAUDE_TASK_BUDGET_TOKENS, then LLM_TASK_BUDGET_TOKENS, then 128000
# CLAUDE_TASK_BUDGET_TOKENS=128000
# LLM_TASK_BUDGET_TOKENS=128000


# -----------------------------------------------------------------------------
# Docker / shell sandbox
# -----------------------------------------------------------------------------
# When enabled, agents use a real filesystem + the deepagents `execute` tool
# (git, curl, python, make, etc.) instead of an in-memory virtual workspace.
#
# In Docker: auto-enabled when /.dockerenv exists (AGENT_SANDBOX=1 in Dockerfile).
# Locally:   off by default — set AGENT_SANDBOX=1 only if you accept full shell
#            access on your host machine.

# Force sandbox on (1) or off (0). Unset = auto-detect Docker.
# AGENT_SANDBOX=1

# Directory for file tools and shell commands. Default: /workspace
# AGENT_WORKSPACE=/workspace

# Max seconds per execute() command. Default: 600
# AGENT_EXECUTE_TIMEOUT=600


# -----------------------------------------------------------------------------
# CLI / terminal (optional)
# -----------------------------------------------------------------------------

# Set to any value to disable colored output in discuss.py roundtable.
# NO_COLOR=1
